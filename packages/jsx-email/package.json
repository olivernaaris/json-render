{
  "name": "@json-render/jsx-email",
  "version": "0.18.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "jsx-email renderer for @json-render/core. JSON becomes HTML emails via jsx-email.",
  "keywords": [
    "json",
    "email",
    "jsx-email",
    "ai",
    "generative-ui",
    "llm",
    "renderer",
    "html"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vercel-labs/json-render.git",
    "directory": "packages/jsx-email"
  },
  "homepage": "https://json-render.dev",
  "bugs": {
    "url": "https://github.com/vercel-labs/json-render/issues"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./server": {
      "types": "./dist/server.d.mts",
      "import": "./dist/server.mjs"
    },
    "./catalog": {
      "types": "./dist/catalog.d.mts",
      "import": "./dist/catalog.mjs"
    },
    "./render": {
      "types": "./dist/render.d.mts",
      "import": "./dist/render.mjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --root ../.. packages/jsx-email/src/render.test.tsx packages/jsx-email/tests/release-tarball-smoke.test.ts",
    "prepack": "pnpm run build",
    "smoke:exports": "node --input-type=module -e \"for (const specifier of ['@json-render/jsx-email','@json-render/jsx-email/catalog','@json-render/jsx-email/render','@json-render/jsx-email/server']) await import(specifier);\"",
    "smoke:tarball": "node scripts/smoke-release-tarball.mjs",
    "check-types": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "jsx-email": "3.2.1"
  },
  "devDependencies": {
    "@jsx-email/plugin-inline": "^2.0.0",
    "@jsx-email/plugin-minify": "^2.0.0",
    "@jsx-email/plugin-pretty": "^2.0.0",
    "@internal/typescript-config": "workspace:*",
    "@json-render/core": "workspace:*",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "canispam": "^1.0.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "@jsx-email/plugin-inline": "^2.0.0",
    "@jsx-email/plugin-minify": "^2.0.0",
    "@jsx-email/plugin-pretty": "^2.0.0",
    "@json-render/core": "*",
    "canispam": "^1.0.0",
    "react": "^19.0.0",
    "zod": "^4.0.0"
  }
}
